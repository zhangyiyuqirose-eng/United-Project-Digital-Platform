# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/updg_db
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/updg_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=united-project-digital-platform-secret-key-must-be-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=86400

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
